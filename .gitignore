/frontend/android/
/frontend/ios/
**/local.properties

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Env
.env
.env.local
.env.*.local

