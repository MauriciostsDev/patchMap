{
  "expo": {
    "name": "PatchMap",
    "slug": "patchmap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "patchmap",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080b11",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b11"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "newArchEnabled": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#080b11"
      },
      "package": "br.gov.patchmap",
      "versionCode": 1,
      "newArchEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "apiUrl": ""
    }
  }
}
